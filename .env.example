PORT=8787
RELAY_SHARED_SECRET=replace-with-shared-secret

# Prefer a single server-held auth mode. Choose one of the following:
#
# 1) User-scoped plugin token already minted on the server:
# PROJECT_USER_PLUGIN_TOKEN=
#
# 2) Shared plugin token plus fixed user key:
# PROJECT_PLUGIN_TOKEN=
# PROJECT_USER_KEY=
#
# 3) Shared plugin id/secret plus fixed user key:
PROJECT_PLUGIN_ID=
PROJECT_PLUGIN_SECRET=
PROJECT_USER_KEY=

PROJECT_KEY=rzoecp
PROJECT_BASE_URL=https://project.feishu.cn/open_api
PROJECT_DEFAULT_WORK_ITEM_TYPE=69ca097070c61cbef714a50f
PROJECT_ASSET_SUBTASK_TYPE=69ca097070c61cbef714a50f

# Recommended for shared proxy mode:
# 1) Set ALLOW_CALLER_USER_KEY=1
# 2) Set REQUIRE_CALLER_USER_KEY=1
# 3) Leave PROJECT_USER_KEY blank unless you want a fallback/default actor
ALLOW_CALLER_USER_KEY=1
REQUIRE_CALLER_USER_KEY=1

# Optional JSONL audit log path. Relative paths are resolved from the repo root.
AUDIT_LOG_PATH=logs/audit.jsonl

# Set to 0 if you want a preview-only environment.
ALLOW_EXECUTE=1
